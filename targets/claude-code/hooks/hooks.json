{
  "description": "Sentinal hooks - quality enforcement + persistent memory for TypeScript/Angular/NestJS",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared post-compact-restore",
            "timeout": 5
          }
        ]
      },
      {
        "once": true,
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared memory-restore",
            "timeout": 5
          }
        ]
      },
      {
        "once": true,
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared tdd-guard",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared pre-edit-guide",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|WebSearch|WebFetch|Grep|EnterPlanMode|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook claude tool-redirect"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared tdd-tracker",
            "timeout": 10,
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "if": "Write(*.ts)|Write(*.tsx)|Edit(*.ts)|Edit(*.tsx)|MultiEdit(*.ts)|MultiEdit(*.tsx)",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook claude file-checker",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared memory-observer",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|MultiEdit|Bash|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook claude context-monitor",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared prompt-context",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared pre-compact",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared spec-stop-guard"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared session-end",
            "timeout": 10
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared stop-failure",
            "timeout": 5
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "project_settings|skills",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared config-change",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared instructions-loaded",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared cwd-changed",
            "timeout": 5
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": ".envrc|*.test.ts|*.spec.ts",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared file-changed",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared post-compact",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared task-created",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
