{
  "description": "Sentinal hooks - quality enforcement + persistent memory for TypeScript/Angular/NestJS",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared post-compact-restore",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared memory-restore",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared tdd-guard",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared pre-edit-guide",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|WebSearch|WebFetch|Grep|EnterPlanMode|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook claude tool-redirect"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared tdd-tracker",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook claude file-checker",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared memory-observer",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|MultiEdit|Bash|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook claude context-monitor",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared pre-compact",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared spec-stop-guard"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sentinal hook shared session-end",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
