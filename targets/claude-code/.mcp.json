{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "web-search": {
      "command": "npx",
      "args": ["-y", "open-websearch"],
      "env": {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo",
        "ALLOWED_SEARCH_ENGINES": "duckduckgo,bing,exa"
      }
    },
    "grep-mcp": {
      "type": "http",
      "url": "https://mcp.grep.app"
    },
    "web-fetch": {
      "command": "npx",
      "args": ["-y", "fetcher-mcp"]
    },
    "sentinal": {
      "command": "sentinal",
      "args": ["mcp-server"]
    }
  }
}
