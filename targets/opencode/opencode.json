{
  "$schema": "https://opencode.ai/config.json",

  "plugin": [
    "@endpoint/sentinal/opencode-plugin"
  ],

  "permission": {
    "skill": {
      "*": "allow",
      "spec-*": "allow"
    },
    "edit": {
      "*": "ask",
      "docs/plans/*.md": "allow",
      "docs/plans/**/*.md": "allow"
    }
  },

  "agent": {
    "build": {
      "permission": {
        "task": {
          "*": "ask",
          "plan-reviewer": "allow",
          "spec-reviewer": "allow",
          "explore": "allow",
          "general": "allow"
        },
        "edit": {
          "*": "allow"
        }
      }
    },
    "plan": {
      "permission": {
        "task": {
          "*": "ask",
          "plan-reviewer": "allow",
          "spec-reviewer": "allow",
          "explore": "allow",
          "general": "allow"
        },
        "edit": {
          "*": "ask",
          "docs/plans/*.md": "allow",
          "docs/plans/**/*.md": "allow"
        }
      }
    }
  },

  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"]
    },
    "web-search": {
      "type": "local", 
      "command": ["npx", "-y", "open-websearch"],
      "environment": {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo",
        "ALLOWED_SEARCH_ENGINES": "duckduckgo,bing,exa"
      }
    },
    "grep-mcp": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "web-fetch": {
      "type": "local",
      "command": ["npx", "-y", "fetcher-mcp"]
    },
    "sentinal": {
      "type": "local",
      "command": ["sentinal", "mcp-server"]
    }
  },

  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"]
    }
  }
}
