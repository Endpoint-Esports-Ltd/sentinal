{
  "name": "@endpoint/sentinal",
  "version": "1.0.3",
  "license": "UNLICENSED",
  "description": "Quality plugin for TypeScript, Angular, and NestJS - supports Claude Code and OpenCode",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "sentinal": "bin/sentinal.sh",
    "sentinal-memory": "bin/sentinal-memory.sh"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.2.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.cloud.endpoint.gg/"
  },
  "scripts": {
    "build": "tsc -p targets/claude-code/tsconfig.json",
    "build:watch": "tsc -p targets/claude-code/tsconfig.json --watch",
    "build:opencode": "bun build targets/opencode/plugins/sentinal.ts --outdir targets/opencode/dist --target bun",
    "build:cli": "bun build --compile src/cli/index.ts --outfile dist/sentinal --define __SENTINAL_VERSION__=\"'$(node -p \"require('./package.json').version\")'\"",
    "build:all": "bun run build && bun run build:opencode",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "install:claude-code": "bun src/cli/index.ts install claude",
    "install:opencode": "bun src/cli/index.ts install opencode",
    "cli": "bun src/cli/index.ts",
    "memory": "bun src/memory/cli.ts",
    "memory:mcp": "bun src/memory/mcp-server.ts"
  },
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xenova/transformers": "^2.17.2",
    "commander": "^14.0.3",
    "sqlite-vec": "^0.1.7-alpha.2",
    "zod": "^3.24.0"
  }
}
