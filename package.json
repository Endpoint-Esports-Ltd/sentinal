{
  "name": "sentinal",
  "version": "0.1.0",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.2.0",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  },
  "description": "Quality plugin for TypeScript, Angular, and NestJS - supports Claude Code and OpenCode",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "build:opencode": "bun build targets/opencode/plugins/sentinal.ts --outdir targets/opencode/dist --target bun",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "install:claude-code": "./install.sh",
    "install:opencode": "./targets/opencode/install.sh",
    "memory": "bun src/memory/cli.ts",
    "memory:mcp": "bun src/memory/mcp-server.ts"
  },
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xenova/transformers": "^2.17.2",
    "sqlite-vec": "^0.1.7-alpha.2"
  }
}
