{
  "name": "@endpoint/sentinal",
  "version": "1.9.0",
  "license": "UNLICENSED",
  "description": "Quality plugin for TypeScript, Angular, and NestJS - supports Claude Code and OpenCode",
  "exports": {
    ".": "./src/index.ts",
    "./opencode-plugin": "./targets/opencode/plugins/sentinal.ts"
  },
  "bin": {
    "sentinal": "bin/sentinal.sh"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.0.0",
    "bun-types": "^1.2.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Endpoint-Esports-Ltd/sentinal.git"
  },
  "publishConfig": {
    "registry": "https://npm.cloud.endpoint.gg/"
  },
  "scripts": {
    "build:claude": "tsc -p targets/claude-code/tsconfig.json",
    "build:claude:watch": "tsc -p targets/claude-code/tsconfig.json --watch",
    "build:opencode": "bun build targets/opencode/plugins/sentinal.ts --outfile targets/opencode/dist/sentinal.mjs --target node --format esm --external bun:sqlite --external @xenova/transformers --external sqlite-vec --external zod",
    "deploy:opencode": "bun run build:opencode && cp targets/opencode/dist/sentinal.mjs ~/.config/opencode/plugins/sentinal.mjs",
    "embed-assets": "bun run build:opencode && node scripts/embed-assets.mjs",
    "build:cli": "bun run embed-assets && bun build --compile src/cli/index.ts --outfile dist/sentinal --define __SENTINAL_VERSION__=\"'$(node -p \"require('./package.json').version\")'\"",
    "build:all": "bun run build:claude && bun run build:opencode",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "install:claude-code": "bun src/cli/index.ts install claude",
    "install:opencode": "bun src/cli/index.ts install opencode",
    "cli": "bun src/cli/index.ts",
    "memory": "bun src/memory/cli.ts",
    "mcp": "bun src/mcp/server.ts"
  },
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@xenova/transformers": "^2.17.2",
    "commander": "^14.0.3",
    "sqlite-vec": "^0.1.7-alpha.2",
    "zod": "^4.0.0"
  }
}
